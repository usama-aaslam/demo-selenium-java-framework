<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Default Suite" parallel="methods" thread-count="4">
  <listeners><listener class-name="listeners.TestListener"/></listeners>
  <parameter name="env" value="staging"/>
  <test name="Smoke Tests"><groups><run><include name="smoke"/></run></groups><classes><class name="tests.LoginTest"/></classes></test>
</suite>
